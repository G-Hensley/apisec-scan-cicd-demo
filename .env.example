# APIsec CI/CD Integration — local docker run testing
# Copy to .env (gitignored), fill in values, then run:
#   docker run --rm --env-file .env apisec/cicd:latest

# Required — get from APIsec dashboard URL:
# https://[your-tenant].apisecapps.com/application/[APP_ID]/instance/[INSTANCE_ID]
APISEC_APPLICATION_ID=[get-from-apisec-dashboard-url]
APISEC_INSTANCE_ID=[get-from-apisec-dashboard-url]

# Required — APIsec dashboard → top-right menu → API Token
APISEC_ACCESS_TOKEN=[get-from-apisec-api-token-menu]

# Optional — failure thresholds (these are the defaults used in CI)
# CVSS score minimum for a finding to count toward failure (0-10)
APISEC_SEVERITY_THRESHOLD=8
# Max qualifying findings before the scan fails (0 = zero tolerance)
APISEC_ERROR_THRESHOLD=0
